config/icon="uid://cd4yxkatgkbln"

[audio]

driver/output_latency=1

[autoload]

"音乐引擎"="*uid://dyv1568phymm2"
"精灵图列表"="*uid://qg20ddd545wi"
"节点提供变量"="*uid://cvkwkanf0vbaq"
"存档"="*uid://bmb5esni20lsd"
